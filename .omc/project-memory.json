      "release:mac": "bun scripts/run-mac-release.mjs",
      "release:win": "bun scripts/run-win-release.mjs",
      "build:ui": "bun run --filter=./ui build",
      "serve:web": "bun scripts/prune-build.mjs && bun scripts/free-ports.mjs 8787 && cargo run -p nomifun-web",
      "test": "bun scripts/prune-build.mjs && cargo test",
      "test:fast": "bun scripts/prune-build.mjs && cargo nextest run",
      "check": "bun run typecheck && bun run check:i18n && bun run check:theme && bun run check:icons && bun run help --check",
