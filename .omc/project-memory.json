      "dev": "bun scripts/prune-build.mjs && bun scripts/free-ports.mjs 5173 && bun scripts/kill-stale-dev.mjs && bun scripts/ensure-ui-dist.mjs && NOMI_CHANNEL=dev tauri dev --config apps/desktop/tauri.conf.json --config apps/desktop/tauri.dev.conf.json",
      "dev:web": "bun scripts/prune-build.mjs && bun scripts/free-ports.mjs 5173 8787 && concurrently -k -n api,ui -c blue,magenta \"cargo run -p nomifun-web -- --port 8787 --dist ui/dist --insecure-no-auth\" \"bun run --filter=./ui dev:web\"",
      "dev:ui": "bun run --filter=./ui dev",
      "build": "CI=true tauri build --config apps/desktop/tauri.conf.json && bun scripts/prune-build.mjs --post",
      "build:mac": "bash scripts/desktop-build-mac.sh",
