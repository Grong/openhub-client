      "check:i18n": "bun scripts/generate-i18n-types.mjs --check",
      "check:theme": "bun scripts/check-theme-contract.mjs",
      "check:icons": "bun scripts/check-icon-imports.mjs",
      "fmt": "cargo fmt",
      "fmt:check": "cargo fmt --check",
      "gen:i18n": "bun scripts/generate-i18n-types.mjs",
      "clean": "bun scripts/prune-build.mjs --release",
      "seed:dev": "bun scripts/seed-dev-from-prod.mjs",
